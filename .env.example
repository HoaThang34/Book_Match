# Sao chép thành .env và đổi các giá trị bí mật trước khi chạy.
# Không commit file .env lên Git.

SECRET_KEY=thay-bang-chuoi-ngau-nhien-it-nhat-32-ky-tu
JWT_SECRET_KEY=thay-bang-jwt-secret-khac-it-nhat-32-ky-tu

FLASK_PORT=5000
FLASK_DEBUG=false

# Đường dẫn tương đối được quy về thư mục gốc dự án (không phải instance/)
DATABASE_URL=sqlite:///data/app.db

JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=Lax

CORS_ORIGINS=http://127.0.0.1:5000,http://localhost:5000

PASSWORD_MIN_LENGTH=8
BCRYPT_ROUNDS=12

RATELIMIT_DEFAULT=120 per hour
RATELIMIT_AUTH=10 per minute

MAX_CONTENT_LENGTH=16384
